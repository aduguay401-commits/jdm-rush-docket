# Copy relevant values into .env.local for local dev; set production values in Vercel.
# Names only — never commit real secrets. (.env* is gitignored; .env.example is opted in.)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (SMTP + addresses)
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ADMIN_EMAIL=
MARCUS_EMAIL=
MARCUS_CC_EMAIL=

# Ops
CRON_SECRET=
DEV_MODE=
NEXT_PUBLIC_APP_URL=

# Twilio (WhatsApp/SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Intake spam guardrails (Layer 2) — shared secret the jdm-rush-next site proxy
# sends as x-intake-proxy-secret. The intake endpoints trust the forwarded
# x-intake-client-ip for per-IP rate limiting ONLY when this matches. MUST equal
# INTAKE_PROXY_SECRET in the jdm-rush-next app. If unset in either app, per-IP
# rate limiting is safely skipped (fail-open) — set the same value in both.
INTAKE_PROXY_SECRET=
